# Copy to .env and fill in:  cp .env.example .env

# ---- Kasm desktop ----
# Password for the desktop login (the username is always `kasm_user`).
VNC_PW=changeme

# ---- Image build ----
# Kasm desktop base image tag (kasmweb/ubuntu-jammy-desktop, multi-arch amd64+arm64).
# See https://hub.docker.com/r/kasmweb/ubuntu-jammy-desktop/tags
KASM_TAG=1.17.0
# OpenClaw prebuilt image to copy the app from (pin a version tag for reproducibility).
# Tags: https://github.com/openclaw/openclaw/pkgs/container/openclaw
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# ---- OpenClaw gateway ----
# Password to log into the OpenClaw gateway UI at http://localhost:18789
# (required — the gateway won't expose the published port without auth).
OPENCLAW_GATEWAY_PASSWORD=clawder

# ---- OpenClaw LLM provider (set ONE; leave the others blank) ----
# DeepSeek (native provider; sets deepseek/deepseek-v4-flash as the default model):
DEEPSEEK_API_KEY=
# Anthropic (Claude), e.g. for claude-opus-4-8 / claude-sonnet-4-6:
ANTHROPIC_API_KEY=
# OpenAI:
OPENAI_API_KEY=
# Local model on your Mac, reachable via host.docker.internal:
#   Ollama:    http://host.docker.internal:11434
#   LM Studio: http://host.docker.internal:1234
OLLAMA_BASE_URL=
